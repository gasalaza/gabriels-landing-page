# ─── Backend service ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Public origin of the site (used for OAuth redirects + secure cookie domain)
PUBLIC_BASE_URL=http://localhost:5173

# SQLite database file path (point at a volume mount in production)
SQLITE_DATABASE_PATH=./data/portfolio.sqlite

# Session secret — REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-generated-64-char-hex-string

# GitHub OAuth App credentials — REQUIRED in production
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Comma-separated GitHub usernames allowed to access /admin
AUTH_ALLOWLIST=gasalaza

# Auth rate-limiting (optional)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# ─── Web (Caddy) service ──────────────────────────────────────────
# PORT=8080
# BACKEND_UPSTREAM=http://backend:3000
